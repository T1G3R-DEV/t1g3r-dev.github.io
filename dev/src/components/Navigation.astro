---
import "bootstrap-icons/font/bootstrap-icons.css";
---

<nav>
    <ul class="nav-list">

        <!-- Always visible -->
        <li class="home">
            <a href="/">
                <img src="/favicon.svg" height="16px" />
                Home
            </a>
        </li>


        <!-- Collapsible items -->
        <li class="nav-item"><a href="/about/">About</a></li>
        <li class="nav-item"><a href="/blog/">Blog</a></li>



        <li> 
            <a href="https://github.com/T1G3R-DEV/" target="_blank">
                <i class="bi bi-github"></i>
            </a>
        </li>
        <li> 
            <a href="mailto:contact@t1g3r.dev" target="_blank">
                <i class="bi bi-envelope"></i>
            </a>
        </li>
        <li>
            <a href="/search/" aria-label="Search">
                <i class="bi bi-search"></i>
            </a>
        </li>
        <!-- Hamburger (mobile only) -->
        <li class="menu-toggle">
            <button class="menutg" aria-label="Toggle Menu">☰</button>
        </li>

    </ul>
</nav>

<script>
    const nav = document.querySelector('.nav-list');
    const toggleBtn = document.querySelector('.menu-toggle button');
    const navItems = document.querySelectorAll('.nav-item');

    toggleBtn.addEventListener('click', () => {
        nav.classList.toggle('open');
    });

    // Close when clicking a link
    navItems.forEach(item => {
        item.addEventListener('click', () => {
            nav.classList.remove('open');
        });
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
        if (!nav.contains(e.target)) {
            nav.classList.remove('open');
        }
    });

    // Close when resizing to desktop
    window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
            nav.classList.remove('open');
        }
    });
</script>
<style>
    nav {
    background-color: #000111;
    position: sticky;
    top: 0;
    z-index: 1000;
}

.nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
}

/* Push everything except Home to the right */
.home {
    margin-right: auto;
}

/* Links */
.nav-list a {
    display: block;
    color: white;
    padding: 14px 16px;
    text-decoration: none;
}

.nav-list a:hover , 
.menu-toggle button:hover{
    background-color: #002e34;
}

/* Hide hamburger on desktop */
.menu-toggle {
    display: none;
}

.menu-toggle button {
    font-size: 24px;
    background: none;
    border: none;
    color: white;
    padding: 8px 16px;
    cursor: pointer;
}
/* ========================= */
/* Mobile */
/* ========================= */

@media (max-aspect-ratio: 1/1) {

    .menu-toggle {
        display: block;
    }

    .nav-list {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }

    /* Keep top-row items fixed */
    .home,
    .search,
    .menu-toggle,
    .nav-list > li:not(.nav-item) {
        flex: 0 0 auto;
    }

    /* Hide collapsible items */
    .nav-item {
        display: none;
    }

    /* When open → show dropdown items */
    .nav-list.open .nav-item {
        display: block;
        flex: 0 0 100%;   /* force full row */
        width: 100%;
        order: 10;        /* ensure they appear after top row */
        background-color: #000111;
    }

    .nav-list.open .nav-item a {
        display: block;
        width: 100%;
        padding: 14px 16px;
        box-sizing: border-box;
    }
}
</style>